{% doc %}
  @prompt
    簡易的なABOUTページ
    左には写真を3枚ランダムな配置で並べる
    右はタイトル(About)を左揃えで配置。
    そのタイトルの下に細い線を配置、
    その線の下に3行くらいの日本語を左揃えで配置
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-about-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  .ai-about-images-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 500px;
  }

  .ai-about-image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-about-image-wrapper-{{ ai_gen_id }}:nth-child(1) {
    width: 45%;
    height: 55%;
    top: 0;
    left: 0;
    z-index: 3;
  }

  .ai-about-image-wrapper-{{ ai_gen_id }}:nth-child(2) {
    width: 50%;
    height: 60%;
    bottom: 0;
    right: 0;
    z-index: 2;
  }

  .ai-about-image-wrapper-{{ ai_gen_id }}:nth-child(3) {
    width: 40%;
    height: 45%;
    top: 30%;
    left: 35%;
    z-index: 1;
  }

  .ai-about-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-about-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-about-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-about-content-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.content_padding }}px;
  }

  .ai-about-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px 0;
    text-align: left;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .ai-about-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 0 {{ block.settings.divider_margin }}px 0;
  }

  .ai-about-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.line_height }};
    text-align: left;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-about-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-about-images-{{ ai_gen_id }} {
      height: 400px;
    }

    .ai-about-content-{{ ai_gen_id }} {
      padding: 0 20px;
    }
  }
{% endstyle %}

<div class="ai-about-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-container-{{ ai_gen_id }}">
    <div class="ai-about-images-{{ ai_gen_id }}">
      <div class="ai-about-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 600 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
            class="ai-about-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-about-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 600 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="ai-about-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-about-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_3 %}
          <img
            src="{{ block.settings.image_3 | image_url: width: 600 }}"
            alt="{{ block.settings.image_3.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_3.width }}"
            height="{{ block.settings.image_3.height }}"
            class="ai-about-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-about-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-about-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      <div class="ai-about-divider-{{ ai_gen_id }}"></div>

      {% if block.settings.text != blank %}
        <div class="ai-about-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "About"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>私たちは、日々を丁寧に生きる女性のために、心に寄り添うジュエリーをお届けしています。ひとつひとつの作品に、静かな気品と優しさを込めて。</p>"
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#4b4b4b"
    },
    {
      "type": "range",
      "id": "title_margin",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Title bottom margin",
      "default": 20
    },
    {
      "type": "header",
      "content": "Divider style"
    },
    {
      "type": "range",
      "id": "divider_width",
      "min": 20,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Divider width",
      "default": 60
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Divider thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#8f9eb2"
    },
    {
      "type": "range",
      "id": "divider_margin",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Divider bottom margin",
      "default": 24
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#4b4b4b"
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Section padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "gap",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Gap between images and content",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 0,
      "max": 60,
      "step": 10,
      "unit": "px",
      "label": "Content padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "About section"
    }
  ]
}
{% endschema %}
