{% doc %}
  @prompt
    写真を3枚ランダムな配置で並べつつ、6用くらいの日本語を中央揃えで配置できる
    ABOUTページ, 写真は最上段
    テキストの下に細い線を1本
    その下にさらにテキスト
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    margin: 0 auto;
  }

  .ai-about-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    align-items: center;
  }

  .ai-about-images-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.images_max_width }}px;
    height: {{ block.settings.images_height }}px;
    margin: 0 auto;
  }

  .ai-about-image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-about-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-about-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-about-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-about-image-1-{{ ai_gen_id }} {
    width: {{ block.settings.image_1_width }}%;
    height: {{ block.settings.image_1_height }}%;
    top: {{ block.settings.image_1_top }}%;
    left: {{ block.settings.image_1_left }}%;
    z-index: {{ block.settings.image_1_z_index }};
  }

  .ai-about-image-2-{{ ai_gen_id }} {
    width: {{ block.settings.image_2_width }}%;
    height: {{ block.settings.image_2_height }}%;
    top: {{ block.settings.image_2_top }}%;
    left: {{ block.settings.image_2_left }}%;
    z-index: {{ block.settings.image_2_z_index }};
  }

  .ai-about-image-3-{{ ai_gen_id }} {
    width: {{ block.settings.image_3_width }}%;
    height: {{ block.settings.image_3_height }}%;
    top: {{ block.settings.image_3_top }}%;
    left: {{ block.settings.image_3_left }}%;
    z-index: {{ block.settings.image_3_z_index }};
  }

  .ai-about-text-top-{{ ai_gen_id }} {
    text-align: center;
    max-width: {{ block.settings.text_max_width }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-about-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 auto;
  }

  .ai-about-text-bottom-{{ ai_gen_id }} {
    text-align: center;
    max-width: {{ block.settings.text_max_width }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-about-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-about-text-top-{{ ai_gen_id }},
    .ai-about-text-bottom-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-about-images-{{ ai_gen_id }} {
      height: {{ block.settings.images_height | times: 0.7 }}px;
    }

    .ai-about-divider-{{ ai_gen_id }} {
      width: {{ block.settings.divider_width | times: 0.8 }}px;
    }
  }
{% endstyle %}

<ai-about-section-{{ ai_gen_id }} class="ai-about-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-container-{{ ai_gen_id }}">
    <div class="ai-about-images-{{ ai_gen_id }}">
      <div class="ai-about-image-wrapper-{{ ai_gen_id }} ai-about-image-1-{{ ai_gen_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 800 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
          >
        {% else %}
          <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-about-image-wrapper-{{ ai_gen_id }} ai-about-image-2-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 800 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
          >
        {% else %}
          <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-about-image-wrapper-{{ ai_gen_id }} ai-about-image-3-{{ ai_gen_id }}">
        {% if block.settings.image_3 %}
          <img
            src="{{ block.settings.image_3 | image_url: width: 800 }}"
            alt="{{ block.settings.image_3.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_3.width }}"
            height="{{ block.settings.image_3.height }}"
          >
        {% else %}
          <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.text_top != blank %}
      <div class="ai-about-text-top-{{ ai_gen_id }}">
        {{ block.settings.text_top }}
      </div>
    {% endif %}

    <div class="ai-about-divider-{{ ai_gen_id }}"></div>

    {% if block.settings.text_bottom != blank %}
      <div class="ai-about-text-bottom-{{ ai_gen_id }}">
        {{ block.settings.text_bottom }}
      </div>
    {% endif %}
  </div>
</ai-about-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiAboutSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('ai-about-section-{{ ai_gen_id }}', AiAboutSection{{ ai_gen_id }});
  })();
</script>

