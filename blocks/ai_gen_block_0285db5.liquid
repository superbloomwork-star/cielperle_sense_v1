{% doc %}
  @prompt
    余白
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: {{ block.settings.spacer_height }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.spacer_height_mobile }}px;
    }
  }
{% endstyle %}

<spacer-block-{{ ai_gen_id }}
  class="ai-spacer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
</spacer-block-{{ ai_gen_id }}>

{% schema %}
{
  "name": "余白",
  "settings": [
    {
      "type": "range",
      "id": "spacer_height",
      "label": "デスクトップの高さ",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "spacer_height_mobile",
      "label": "モバイルの高さ",
      "min": 10,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "余白"
    }
  ]
}
{% endschema %}